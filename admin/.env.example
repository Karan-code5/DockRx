# ─── DockRx Admin Panel — Environment Variables ──────────────────────────────
# Copy this file: cp .env.example .env
# Then fill in your values. Never commit the .env file.
# All variables MUST start with VITE_ to be accessible in the browser.

# ── Backend API URL ───────────────────────────────────────────────────────────
# Local dev:   http://localhost:4000
# Render:      https://dockrx-backend.onrender.com
# Cloudflare:  https://dockrx.YOUR_SUBDOMAIN.workers.dev
VITE_BACKEND_URL=http://localhost:4000

# ── Currency Symbol ───────────────────────────────────────────────────────────
# Displayed in the UI next to prices. Examples: ₹ $ €
VITE_CURRENCY=₹
