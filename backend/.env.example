# ─── DockRx Backend — Environment Variables ─────────────────────────────────
# Copy this file: cp .env.example .env
# Then fill in all values. Never commit the .env file.

# ── Currency ─────────────────────────────────────────────────────────────────
# Currency code used internally. Examples: INR, USD, EUR
CURRENCY=INR

# ── Authentication ────────────────────────────────────────────────────────────
# Long random string for signing JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Admin Credentials ────────────────────────────────────────────────────────
# These are the credentials used to log in to the Admin Panel.
# Set a strong password. Only ONE admin account is supported.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. Do NOT append a database name at the end.
# Get it from: Atlas Dashboard → Connect → Drivers → Copy URI
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net
MONGODB_URI=

# ── Cloudinary (Image Storage — Local Dev & Render) ──────────────────────────
# Used for doctor/patient profile image uploads when running in Node.js mode.
# Sign up free at: https://cloudinary.com
# Get these from: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

# ── Razorpay (Payment Gateway — Optional) ────────────────────────────────────
# Required only if you want to test/use Razorpay payment flow.
# Get test keys from: https://dashboard.razorpay.com → Account & Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Stripe (Payment Gateway — Optional) ──────────────────────────────────────
# Required only if you want to test/use Stripe payment flow.
# Get test keys from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
