.env
.env.local
.env.*.local
*/.env
*/.env.local
*/.env.*.local

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
*/node_modules/

# ─── Build Outputs ────────────────────────────────────────────────────────────
dist/
*/dist/
build/
*/build/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

